.container {
  padding-bottom: 20rpx;
}

/* 搜索栏 */
.search-bar {
  display: flex;
  align-items: center;
  background: #f5f5f5;
  margin: 20rpx;
  padding: 20rpx 30rpx;
  border-radius: 50rpx;
}

.search-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 16rpx;
}

.search-placeholder {
  color: #999;
  font-size: 26rpx;
}

/* 轮播图 */
.banner-swiper {
  width: 100%;
  height: 420rpx;
  margin-bottom: 20rpx;
}

.banner-image {
  width: 100%;
  height: 100%;
}

/* 快捷入口 */
.quick-nav {
  display: flex;
  flex-wrap: wrap;
  background: white;
  padding: 30rpx 20rpx;
  margin: 0 20rpx 20rpx;
  border-radius: 16rpx;
}

.nav-item {
  width: 25%;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 20rpx;
}

.nav-icon {
  width: 88rpx;
  height: 88rpx;
  margin-bottom: 12rpx;
  border-radius: 50%;
}

.nav-text {
  font-size: 24rpx;
  color: #333;
}

/* 通用区块 */
.section {
  background: white;
  margin-bottom: 20rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 24rpx;
}

.section-title {
  display: flex;
  align-items: center;
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.title-dot {
  width: 8rpx;
  height: 28rpx;
  background: linear-gradient(180deg, #ff4d6d, #ff8fa3);
  border-radius: 4rpx;
  margin-right: 16rpx;
}

.section-more {
  font-size: 24rpx;
  color: #999;
}

/* 倒计时 */
.countdown {
  display: flex;
  align-items: center;
  margin-left: 20rpx;
}

.countdown-num {
  background: #333;
  color: white;
  font-size: 22rpx;
  padding: 4rpx 8rpx;
  border-radius: 4rpx;
  min-width: 36rpx;
  text-align: center;
}

.countdown-colon {
  margin: 0 4rpx;
  font-weight: bold;
}

/* 限时秒杀 */
.flash-list {
  display: flex;
  white-space: nowrap;
  padding: 0 24rpx 30rpx;
}

.flash-item {
  display: inline-block;
  width: 200rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.flash-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
}

.flash-price {
  display: flex;
  align-items: baseline;
  margin-bottom: 8rpx;
}

.flash-price-value {
  color: #ff4d6d;
  font-size: 32rpx;
  font-weight: 700;
}

.flash-price-original {
  color: #999;
  font-size: 22rpx;
  text-decoration: line-through;
  margin-left: 8rpx;
}

.flash-progress {
  position: relative;
  height: 16rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  overflow: hidden;
}

.flash-progress-bar {
  height: 100%;
  background: linear-gradient(90deg, #ff4d6d, #ff8fa3);
  border-radius: 8rpx;
}

.flash-progress-text {
  position: absolute;
  right: 0;
  top: -4rpx;
  font-size: 20rpx;
  color: #ff4d6d;
}

/* 新品上市 */
.new-arrival {
  display: flex;
  padding: 0 24rpx 30rpx;
  gap: 20rpx;
}

.new-item.big {
  width: 330rpx;
  flex-shrink: 0;
}

.new-small-list {
  flex: 1;
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.new-item.small {
  width: calc(50% - 10rpx);
}

.new-image {
  width: 100%;
  height: 330rpx;
  border-radius: 12rpx;
}

.new-item.big .new-image {
  height: 500rpx;
}

.new-item {
  position: relative;
}

.new-tag {
  position: absolute;
  top: 12rpx;
  left: 12rpx;
  background: #333;
  color: white;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
}

.new-info {
  padding: 16rpx 0;
}

.new-name {
  font-size: 26rpx;
  color: #333;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.new-price {
  color: #ff4d6d;
  font-size: 30rpx;
  font-weight: 700;
}

/* 热销榜单 */
.hot-list {
  display: flex;
  white-space: nowrap;
  padding: 0 24rpx 30rpx;
}

.hot-item {
  display: inline-flex;
  align-items: center;
  width: 400rpx;
  margin-right: 24rpx;
  background: #fafafa;
  border-radius: 12rpx;
  padding: 20rpx;
  flex-shrink: 0;
}

.hot-rank {
  width: 48rpx;
  height: 48rpx;
  background: linear-gradient(180deg, #ff4d6d, #ff8fa3);
  color: white;
  font-size: 24rpx;
  font-weight: 700;
  text-align: center;
  line-height: 48rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.hot-item:nth-child(2) .hot-rank {
  background: linear-gradient(180deg, #ff8fa3, #ffb4c1);
}

.hot-item:nth-child(3) .hot-rank {
  background: linear-gradient(180deg, #ffd43b, #ffe066);
}

.hot-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.hot-info {
  flex: 1;
  min-width: 0;
}

.hot-name {
  font-size: 26rpx;
  color: #333;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.hot-sales {
  font-size: 22rpx;
  color: #999;
}

/* 推荐商品 */
.product-image-wrapper {
  position: relative;
}

.product-tags {
  position: absolute;
  top: 12rpx;
  left: 12rpx;
}

.bottom-space {
  height: 40rpx;
}
