.container {
  min-height: 100vh;
  background: #f8f8f8;
  padding-bottom: 40rpx;
}

/* 用户信息区域 */
.user-section {
  display: flex;
  align-items: center;
  padding: 60rpx 30rpx 40rpx;
  background: linear-gradient(135deg, #ff4d6d, #ff8fa3);
  position: relative;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  margin-right: 24rpx;
}

.user-info {
  flex: 1;
}

.user-name {
  font-size: 32rpx;
  font-weight: 600;
  color: white;
  margin-bottom: 8rpx;
}

.user-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.setting-icon {
  width: 40rpx;
  height: 40rpx;
}

/* 订单入口 */
.order-section {
  background: white;
  margin: 20rpx;
  border-radius: 16rpx;
  padding: 30rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.section-more {
  font-size: 24rpx;
  color: #999;
}

.order-tabs {
  display: flex;
  justify-content: space-between;
}

.order-tab {
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
}

.tab-icon {
  width: 56rpx;
  height: 56rpx;
  margin-bottom: 12rpx;
}

.tab-text {
  font-size: 22rpx;
  color: #666;
}

.tab-badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  min-width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  text-align: center;
  background: #ff4d6d;
  color: white;
  font-size: 18rpx;
  border-radius: 16rpx;
  padding: 0 6rpx;
}

/* 我的资产 */
.assets-section {
  background: white;
  margin: 20rpx;
  border-radius: 16rpx;
  padding: 30rpx;
}

.assets-list {
  display: flex;
  justify-content: space-around;
}

.asset-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.asset-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 8rpx;
}

.asset-label {
  font-size: 22rpx;
  color: #999;
}

/* 菜单列表 */
.menu-section {
  background: white;
  margin: 20rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  width: 44rpx;
  height: 44rpx;
  margin-right: 20rpx;
}

.menu-text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.menu-arrow {
  width: 24rpx;
  height: 24rpx;
}

/* 退出登录 */
.logout-btn {
  margin: 40rpx 20rpx;
  background: white;
  color: #ff4d6d;
  text-align: center;
  padding: 30rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
}

.bottom-space {
  height: 40rpx;
}
