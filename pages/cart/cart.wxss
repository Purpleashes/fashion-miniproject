.container {
  min-height: 100vh;
  background: #f8f8f8;
  padding-bottom: 120rpx;
}

/* 空购物车 */
.empty-cart {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
}

.empty-image {
  width: 300rpx;
  height: 300rpx;
  opacity: 0.3;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 40rpx;
}

.btn-go-shopping {
  background: linear-gradient(135deg, #ff4d6d, #ff8fa3);
  color: white;
  padding: 20rpx 60rpx;
  border-radius: 50rpx;
  font-size: 28rpx;
}

/* 购物车列表 */
.cart-list {
  padding-bottom: 120rpx;
}

.cart-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 30rpx;
  background: white;
  margin-bottom: 20rpx;
}

.select-all {
  display: flex;
  align-items: center;
}

.checkbox {
  width: 40rpx;
  height: 40rpx;
  margin-right: 16rpx;
}

.select-all text {
  font-size: 26rpx;
  color: #333;
}

.edit-btn {
  font-size: 26rpx;
  color: #666;
}

/* 商品列表 */
.cart-items {
  max-height: 70vh;
}

.cart-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  background: white;
  margin-bottom: 20rpx;
  position: relative;
}

.item-checkbox {
  margin-right: 20rpx;
}

.item-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
}

.item-info {
  flex: 1;
  min-width: 0;
}

.item-name {
  font-size: 26rpx;
  color: #333;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.item-spec {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.item-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.item-price {
  display: flex;
  align-items: baseline;
}

.item-price .symbol {
  font-size: 22rpx;
  color: #ff4d6d;
  margin-right: 4rpx;
}

.item-price .price {
  font-size: 32rpx;
  font-weight: 700;
  color: #ff4d6d;
}

.quantity-wrapper {
  display: flex;
  align-items: center;
  border: 1rpx solid #e0e0e0;
  border-radius: 8rpx;
  overflow: hidden;
}

.quantity-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #333;
  background: #f8f8f8;
}

.quantity-value {
  width: 70rpx;
  height: 56rpx;
  line-height: 56rpx;
  text-align: center;
  font-size: 24rpx;
  border-left: 1rpx solid #e0e0e0;
  border-right: 1rpx solid #e0e0e0;
}

.item-delete {
  position: absolute;
  right: 0;
  top: 0;
  bottom: 0;
  width: 120rpx;
  background: #ff4d6d;
  display: flex;
  align-items: center;
  justify-content: center;
}

.delete-icon {
  width: 40rpx;
  height: 40rpx;
}

/* 推荐商品 */
.recommend-section {
  background: white;
  margin-top: 20rpx;
  padding: 30rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

.recommend-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.recommend-item {
  width: calc(50% - 10rpx);
  background: #fafafa;
  border-radius: 12rpx;
  overflow: hidden;
}

.recommend-image {
  width: 100%;
  height: 300rpx;
}

.recommend-name {
  font-size: 24rpx;
  color: #333;
  padding: 16rpx 16rpx 8rpx;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.recommend-price {
  font-size: 28rpx;
  font-weight: 700;
  color: #ff4d6d;
  padding: 0 16rpx 16rpx;
}

/* 底部结算栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: white;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 30rpx;
  border-top: 1rpx solid #f0f0f0;
  z-index: 100;
}

.bar-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.total-info {
  margin-left: 30rpx;
}

.total-label {
  font-size: 26rpx;
  color: #333;
}

.total-price {
  margin-left: 12rpx;
}

.total-price .symbol {
  font-size: 22rpx;
  color: #ff4d6d;
}

.total-price .price {
  font-size: 36rpx;
  font-weight: 700;
  color: #ff4d6d;
}

.total-desc {
  font-size: 20rpx;
  color: #999;
  margin-left: 12rpx;
}

.bar-right {
  display: flex;
  gap: 16rpx;
}

.btn {
  padding: 20rpx 40rpx;
  border-radius: 50rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.btn-delete {
  background: #f0f0f0;
  color: #333;
}

.btn-primary {
  background: linear-gradient(135deg, #ff4d6d, #ff8fa3);
  color: white;
}
