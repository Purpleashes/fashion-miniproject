<view class="container">
  <!-- 空状态 -->
  <view class="empty-cart" wx:if="{{cartList.length === 0}}">
    <image src="/images/cart/empty-cart.png" class="empty-image"></image>
    <text class="empty-text">购物车空空如也~</text>
    <view class="btn-go-shopping" bindtap="goShopping">去逛逛</view>
  </view>

  <!-- 购物车列表 -->
  <view class="cart-list" wx:else>
    <!-- 顶部全选 -->
    <view class="cart-header">
      <view class="select-all" bindtap="toggleSelectAll">
        <image src="{{isAllSelected ? '/images/common/checkbox-checked.png' : '/images/common/checkbox.png'}}" class="checkbox"></image>
        <text>全选</text>
      </view>
      <view class="edit-btn" bindtap="toggleEdit">{{isEditing ? '完成' : '编辑'}}</view>
    </view>

    <!-- 商品列表 -->
    <scroll-view class="cart-items" scroll-y>
      <view class="cart-item" wx:for="{{cartList}}" wx:key="id">
        <view class="item-checkbox" bindtap="toggleItemSelect" data-index="{{index}}">
          <image src="{{item.selected ? '/images/common/checkbox-checked.png' : '/images/common/checkbox.png'}}" class="checkbox"></image>
        </view>
        <image src="{{item.image}}" class="item-image" bindtap="goToDetail" data-id="{{item.id}}"></image>
        <view class="item-info">
          <view class="item-name" bindtap="goToDetail" data-id="{{item.id}}">{{item.name}}</view>
          <view class="item-spec">{{item.spec}}</view>
          <view class="item-bottom">
            <view class="item-price">
              <text class="symbol">¥</text>
              <text class="price">{{item.price}}</text>
            </view>
            <view class="quantity-wrapper">
              <view class="quantity-btn" bindtap="decreaseQuantity" data-index="{{index}}">-</view>
              <text class="quantity-value">{{item.quantity}}</text>
              <view class="quantity-btn" bindtap="increaseQuantity" data-index="{{index}}">+</view>
            </view>
          </view>
        </view>
        <view class="item-delete" wx:if="{{isEditing}}" bindtap="deleteItem" data-index="{{index}}">
          <image src="/images/common/delete.png" class="delete-icon"></image>
        </view>
      </view>
    </scroll-view>

    <!-- 推荐商品 -->
    <view class="recommend-section">
      <view class="section-title">猜你喜欢</view>
      <view class="recommend-list">
        <view class="recommend-item" wx:for="{{recommendProducts}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}">
          <image src="{{item.image}}" class="recommend-image"></image>
          <view class="recommend-name">{{item.name}}</view>
          <view class="recommend-price">¥{{item.price}}</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部结算栏 -->
  <view class="bottom-bar safe-area-bottom" wx:if="{{cartList.length > 0}}">
    <view class="bar-left">
      <view class="select-all" bindtap="toggleSelectAll">
        <image src="{{isAllSelected ? '/images/common/checkbox-checked.png' : '/images/common/checkbox.png'}}" class="checkbox"></image>
        <text wx:if="{{!isEditing}}">全选</text>
      </view>
      <view class="total-info" wx:if="{{!isEditing}}">
        <text class="total-label">合计:</text>
        <text class="total-price">
          <text class="symbol">¥</text>
          <text class="price">{{totalPrice}}</text>
        </text>
        <text class="total-desc">免运费</text>
      </view>
    </view>
    <view class="bar-right">
      <view class="btn btn-delete" wx:if="{{isEditing}}" bindtap="deleteSelected">删除</view>
      <view class="btn btn-primary" wx:else bindtap="goCheckout">
        结算({{selectedCount}})
      </view>
    </view>
  </view>
</view>
