.container {
  padding-bottom: 120rpx;
}

/* 商品图片 */
.image-swiper {
  width: 100%;
  height: 750rpx;
  background: white;
}

.product-image {
  width: 100%;
  height: 100%;
}

/* 顶部导航 */
.top-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  display: flex;
  justify-content: space-between;
  padding: 20rpx;
  z-index: 100;
}

.nav-btn {
  width: 72rpx;
  height: 72rpx;
  background: rgba(0, 0, 0, 0.5);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-icon {
  width: 36rpx;
  height: 36rpx;
}

/* 商品信息 */
.product-info {
  background: white;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.price-row {
  display: flex;
  align-items: baseline;
  margin-bottom: 20rpx;
}

.price {
  display: flex;
  align-items: baseline;
}

.price .symbol {
  font-size: 28rpx;
  color: #ff4d6d;
  margin-right: 4rpx;
}

.price .value {
  font-size: 48rpx;
  font-weight: 700;
  color: #ff4d6d;
}

.original-price {
  font-size: 26rpx;
  color: #999;
  text-decoration: line-through;
  margin-left: 16rpx;
}

.discount {
  font-size: 22rpx;
  color: #ff4d6d;
  border: 1rpx solid #ff4d6d;
  border-radius: 4rpx;
  padding: 2rpx 8rpx;
  margin-left: 12rpx;
}

.sales-tag {
  margin-left: auto;
  background: linear-gradient(135deg, #ff4d6d, #ff8fa3);
  color: white;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
}

.product-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.5;
  margin-bottom: 12rpx;
}

.product-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 20rpx;
}

.tags-row {
  margin-bottom: 20rpx;
}

.tags-row .tag {
  display: inline-block;
  font-size: 22rpx;
  color: #ff4d6d;
  background: #fff1f3;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
  margin-right: 12rpx;
}

.sales-info {
  font-size: 24rpx;
  color: #999;
}

.sales-info text {
  margin-right: 16rpx;
}

/* 选择规格 */
.spec-section {
  display: flex;
  align-items: center;
  background: white;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.spec-label {
  font-size: 28rpx;
  color: #333;
  margin-right: 30rpx;
}

.spec-value {
  flex: 1;
  font-size: 26rpx;
  color: #999;
}

.arrow-icon {
  width: 24rpx;
  height: 24rpx;
}

/* 评价区域 */
.review-section {
  background: white;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.section-more {
  font-size: 24rpx;
  color: #999;
}

.review-stats {
  display: flex;
  justify-content: space-around;
  padding: 30rpx 0;
  background: #fafafa;
  border-radius: 12rpx;
  margin-bottom: 30rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #ff4d6d;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 22rpx;
  color: #999;
}

.review-list {
  border-top: 1rpx solid #f0f0f0;
}

.review-item {
  padding: 30rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.review-item:last-child {
  border-bottom: none;
}

.review-user {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.user-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  margin-right: 16rpx;
}

.user-name {
  font-size: 26rpx;
  color: #333;
  margin-right: 16rpx;
}

.review-time {
  font-size: 22rpx;
  color: #999;
}

.review-spec {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.review-content {
  font-size: 26rpx;
  color: #333;
  line-height: 1.6;
  margin-bottom: 16rpx;
}

.review-images {
  display: flex;
  gap: 12rpx;
}

.review-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 8rpx;
}

/* 详情图片 */
.detail-images {
  background: white;
  padding: 30rpx 0;
}

.detail-images .section-title {
  padding: 0 30rpx;
  margin-bottom: 30rpx;
}

.detail-image {
  width: 100%;
  display: block;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: white;
  display: flex;
  padding: 16rpx 20rpx;
  border-top: 1rpx solid #f0f0f0;
  z-index: 100;
}

.bar-left {
  display: flex;
  flex: 0 0 200rpx;
}

.bar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
}

.bar-icon {
  width: 44rpx;
  height: 44rpx;
  margin-bottom: 4rpx;
}

.bar-item text {
  font-size: 20rpx;
  color: #666;
}

.cart-badge {
  position: absolute;
  top: 0;
  right: 20rpx;
  background: #ff4d6d;
  color: white;
  font-size: 18rpx;
  padding: 2rpx 10rpx;
  border-radius: 20rpx;
  min-width: 28rpx;
  text-align: center;
}

.bar-right {
  display: flex;
  flex: 1;
  margin-left: 20rpx;
  gap: 16rpx;
}

.btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 50rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.btn-cart {
  background: linear-gradient(135deg, #ffd43b, #fab005);
  color: #333;
}

.btn-buy {
  background: linear-gradient(135deg, #ff4d6d, #ff8fa3);
  color: white;
}

.btn-primary {
  background: linear-gradient(135deg, #ff4d6d, #ff8fa3);
  color: white;
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 50rpx;
  font-size: 30rpx;
  font-weight: 600;
}

/* 规格选择弹窗 */
.spec-modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 200;
}

.spec-modal {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: white;
  border-radius: 24rpx 24rpx 0 0;
  z-index: 201;
  transform: translateY(100%);
  transition: transform 0.3s;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
}

.spec-modal.show {
  transform: translateY(0);
}

.modal-header {
  display: flex;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  margin-right: 24rpx;
}

.modal-info {
  flex: 1;
}

.modal-price {
  font-size: 36rpx;
  font-weight: 700;
  color: #ff4d6d;
  margin-bottom: 12rpx;
}

.modal-stock {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.modal-selected {
  font-size: 24rpx;
  color: #666;
}

.modal-close {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.close-icon {
  width: 36rpx;
  height: 36rpx;
}

.modal-body {
  flex: 1;
  padding: 30rpx;
  overflow-y: auto;
}

.spec-group {
  margin-bottom: 40rpx;
}

.spec-group-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.spec-options {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.spec-option {
  min-width: 140rpx;
  padding: 16rpx 24rpx;
  background: #f8f8f8;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #333;
  text-align: center;
  border: 2rpx solid transparent;
  position: relative;
}

.spec-option.active {
  background: #fff1f3;
  border-color: #ff4d6d;
  color: #ff4d6d;
}

.color-image {
  width: 100%;
  height: 80rpx;
  border-radius: 4rpx;
  margin-bottom: 8rpx;
}

.size-tip {
  display: block;
  font-size: 18rpx;
  color: #999;
  margin-top: 4rpx;
}

.size-guide {
  font-size: 24rpx;
  color: #ff4d6d;
  margin-top: 16rpx;
}

.quantity-selector {
  display: inline-flex;
  align-items: center;
  border: 1rpx solid #e0e0e0;
  border-radius: 8rpx;
  overflow: hidden;
}

.quantity-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #333;
  background: #f8f8f8;
}

.quantity-value {
  width: 100rpx;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  font-size: 28rpx;
  border-left: 1rpx solid #e0e0e0;
  border-right: 1rpx solid #e0e0e0;
}

.modal-footer {
  padding: 20rpx 30rpx;
  border-top: 1rpx solid #f0f0f0;
}
