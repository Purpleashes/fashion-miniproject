page {
  background-color: #f8f8f8;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', Arial, sans-serif;
}

.container {
  min-height: 100vh;
}

/* 通用卡片样式 */
.card {
  background: white;
  border-radius: 12rpx;
  margin: 20rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

/* 价格样式 */
.price {
  color: #ff4d6d;
  font-weight: 700;
}

.price-symbol {
  font-size: 24rpx;
  margin-right: 4rpx;
}

.price-value {
  font-size: 36rpx;
}

.original-price {
  color: #999;
  font-size: 24rpx;
  text-decoration: line-through;
  margin-left: 12rpx;
}

/* 商品标签 */
.tag {
  display: inline-block;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
  margin-right: 8rpx;
}

.tag-hot {
  background: linear-gradient(135deg, #ff4d6d, #ff8fa3);
  color: white;
}

.tag-new {
  background: linear-gradient(135deg, #ffd43b, #fab005);
  color: white;
}

.tag-sale {
  background: linear-gradient(135deg, #69db7c, #40c057);
  color: white;
}

/* 按钮样式 */
.btn-primary {
  background: linear-gradient(135deg, #ff4d6d, #ff8fa3);
  color: white;
  border-radius: 50rpx;
  padding: 20rpx 40rpx;
  font-size: 28rpx;
  border: none;
  text-align: center;
}

.btn-outline {
  background: white;
  color: #ff4d6d;
  border: 2rpx solid #ff4d6d;
  border-radius: 50rpx;
  padding: 18rpx 38rpx;
  font-size: 28rpx;
  text-align: center;
}

/* 分割线 */
.divider {
  height: 16rpx;
  background: #f8f8f8;
}

/* 商品网格 */
.product-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 20rpx;
  gap: 20rpx;
}

.product-item {
  width: calc(50% - 10rpx);
  background: white;
  border-radius: 12rpx;
  overflow: hidden;
}

.product-image {
  width: 100%;
  height: 400rpx;
}

.product-info {
  padding: 16rpx;
}

.product-name {
  font-size: 26rpx;
  color: #333;
  line-height: 1.4;
  margin-bottom: 8rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.product-price-row {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
}

.product-sales {
  font-size: 22rpx;
  color: #999;
}

/* 底部安全区 */
.safe-area-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}
